{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Lumen",
	"version": "2026.7.14",
	"identifier": "dev.blmk.lumen",
	"build": {
		"frontendDist": "../ui"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Lumen — Light L16 · isamarin × BLMK",
				"width": 1280,
				"height": 840,
				"minWidth": 960,
				"minHeight": 640,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": false,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}